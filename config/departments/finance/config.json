{
  "id": "finance",
  "name": "财务部",
  "head": "accountant",
  "interval": 600,
  "enabled": false,
  "agents": [
    "cost-analyst",
    "accountant"
  ],
  "budget": {
    "dailyTokenLimit": 500000,
    "alertThreshold": 0.8
  },
  "kpis": {},
  "nameEn": "Finance",
  "emoji": "💰",
  "order": 2,
  "floorColor": {
    "h": 45,
    "s": 35,
    "b": 12,
    "c": 0
  },
  "furniture": [
    {
      "type": "desk",
      "count": 3
    },
    {
      "type": "bookshelf",
      "count": 1
    },
    {
      "type": "plant",
      "count": 1
    }
  ],
  "workflow": {
    "phases": [
      {
        "key": "analysis",
        "labelZh": "分析",
        "labelEn": "Analysis"
      },
      {
        "key": "planning",
        "labelZh": "规划",
        "labelEn": "Planning"
      },
      {
        "key": "execution",
        "labelZh": "执行",
        "labelEn": "Execution"
      },
      {
        "key": "audit",
        "labelZh": "审计",
        "labelEn": "Audit"
      },
      {
        "key": "reporting",
        "labelZh": "报告",
        "labelEn": "Reporting"
      }
    ],
    "taskTypes": [
      {
        "value": "analysis",
        "labelZh": "分析",
        "labelEn": "Analysis",
        "color": "blue"
      },
      {
        "value": "planning",
        "labelZh": "规划",
        "labelEn": "Planning",
        "color": "purple"
      },
      {
        "value": "execution",
        "labelZh": "执行",
        "labelEn": "Execution",
        "color": "green"
      },
      {
        "value": "audit",
        "labelZh": "审计",
        "labelEn": "Audit",
        "color": "amber"
      },
      {
        "value": "reporting",
        "labelZh": "报告",
        "labelEn": "Reporting",
        "color": "cyan"
      }
    ],
    "directories": [
      "analysis",
      "plans",
      "reports",
      "audit"
    ],
    "pipeline": [
      {
        "from": "execution",
        "to": "audit",
        "qualityGate": {
          "minScore": 80,
          "requireSelfCheck": true,
          "maxReworks": 3,
          "validators": ["similarity"],
          "validatorConfig": { "similarity": { "maxRepeatRatio": 0.3, "minBlockSize": 100 } }
        }
      },
      {
        "from": "audit",
        "to": "reporting",
        "qualityGate": {
          "minScore": 85,
          "requireSelfCheck": true,
          "requirePeerReview": true,
          "maxReworks": 2,
          "validators": ["similarity"],
          "validatorConfig": { "similarity": { "maxRepeatRatio": 0.3, "minBlockSize": 100 } }
        }
      }
    ]
  }
}
