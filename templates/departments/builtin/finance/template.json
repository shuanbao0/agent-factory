        { "from": "audit", "to": "reporting", "qualityGate": { "minScore": 85, "requireSelfCheck": true, "requirePeerReview": true, "maxReworks": 2, "validators": ["similarity"], "validatorConfig": { "similarity": { "maxRepeatRatio": 0.3, "minBlockSize": 100 } } } }
      ]
    },
    "floorColor": { "h": 45, "s": 35, "b": 12, "c": 0 },
    "furniture": [
      { "type": "desk", "count": 3 },
      { "type": "bookshelf", "count": 1 },
      { "type": "plant", "count": 1 }
    ],
