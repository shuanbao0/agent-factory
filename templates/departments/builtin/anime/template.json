{
  "id": "anime",
  "name": "动漫制作部",
  "nameEn": "Anime Production",
  "description": "制作短剧、漫剧内容，通过短视频平台分发，获取流量变现收入",
  "descriptionEn": "Produce short anime/manga content for short-video platform monetization",
  "emoji": "🎬",
  "category": "builtin",
  "recommendedAgents": ["anime-director", "script-adapter", "storyboard-artist", "anime-char-designer", "art-director", "animation-supervisor", "post-producer", "sound-director"],
  "defaults": {
    "head": "anime-director",
    "interval": 600,
    "budget": { "dailyTokenLimit": 500000, "alertThreshold": 0.8 },
    "kpis": {},
    "workflow": {
      "phases": [
        { "key": "concept", "labelZh": "企划", "labelEn": "Concept" },
        { "key": "script", "labelZh": "脚本", "labelEn": "Script" },
        { "key": "storyboard", "labelZh": "分镜", "labelEn": "Storyboard" },
        { "key": "production", "labelZh": "制作", "labelEn": "Production" },
        { "key": "postproduction", "labelZh": "后期", "labelEn": "Post-production" },
        { "key": "distribution", "labelZh": "发行", "labelEn": "Distribution" }
      ],
      "taskTypes": [
        { "value": "concept", "labelZh": "企划", "labelEn": "Concept", "color": "blue" },
        { "value": "script", "labelZh": "脚本", "labelEn": "Script", "color": "purple" },
        { "value": "storyboard", "labelZh": "分镜", "labelEn": "Storyboard", "color": "amber" },
        { "value": "animation", "labelZh": "制作", "labelEn": "Animation", "color": "green" },
        { "value": "post-production", "labelZh": "后期", "labelEn": "Post-production", "color": "rose" },
        { "value": "review", "labelZh": "审核", "labelEn": "Review", "color": "pink" }
      ],
      "directories": ["concept", "script", "storyboard", "assets", "postproduction"],
      "pipeline": [
        { "from": "animation", "to": "post-production", "qualityGate": { "minScore": 75, "requireSelfCheck": true, "maxReworks": 3, "validators": ["similarity"], "validatorConfig": { "similarity": { "maxRepeatRatio": 0.3, "minBlockSize": 100 } } } },
        { "from": "post-production", "to": "review", "qualityGate": { "minScore": 75, "requireSelfCheck": true, "requirePeerReview": true, "maxReworks": 2, "validators": ["similarity"], "validatorConfig": { "similarity": { "maxRepeatRatio": 0.3, "minBlockSize": 100 } } } }
      ]
    },
    "floorColor": { "h": 280, "s": 30, "b": 14, "c": 0 },
    "furniture": [
      { "type": "desk", "count": 4 },
      { "type": "whiteboard", "count": 1 },
      { "type": "bookshelf", "count": 1 },
      { "type": "lamp", "count": 2 },
      { "type": "plant", "count": 1 }
    ],
    "order": 9
  }
}
