{
  "id": "research",
  "name": "研究院",
  "nameEn": "Research Lab",
  "description": "追踪前沿 AI 技术，孵化可商业化的技术方案，提供技术竞争力",
  "descriptionEn": "Track cutting-edge AI tech, incubate commercializable solutions",
  "emoji": "🔬",
  "category": "builtin",
  "recommendedAgents": ["chief-scientist", "ai-researcher", "innovation-analyst"],
  "defaults": {
    "head": "chief-scientist",
    "interval": 600,
    "budget": { "dailyTokenLimit": 500000, "alertThreshold": 0.8 },
    "kpis": {},
    "workflow": {
      "phases": [
        { "key": "topic", "labelZh": "选题", "labelEn": "Topic Selection" },
        { "key": "research", "labelZh": "调研", "labelEn": "Research" },
        { "key": "experiment", "labelZh": "实验", "labelEn": "Experiment" },
        { "key": "analysis", "labelZh": "分析", "labelEn": "Analysis" },
        { "key": "publication", "labelZh": "发表", "labelEn": "Publication" }
      ],
      "taskTypes": [
        { "value": "topic", "labelZh": "选题", "labelEn": "Topic", "color": "blue" },
        { "value": "research", "labelZh": "调研", "labelEn": "Research", "color": "purple" },
        { "value": "experiment", "labelZh": "实验", "labelEn": "Experiment", "color": "green" },
        { "value": "analysis", "labelZh": "分析", "labelEn": "Analysis", "color": "amber" },
        { "value": "publication", "labelZh": "发表", "labelEn": "Publication", "color": "cyan" }
      ],
      "directories": ["topics", "literature", "experiments", "analysis", "papers"],
      "pipeline": [
        { "from": "experiment", "to": "analysis", "qualityGate": { "minScore": 75, "requireSelfCheck": true, "maxReworks": 3, "validators": ["similarity"], "validatorConfig": { "similarity": { "maxRepeatRatio": 0.3, "minBlockSize": 100 } } } },
        { "from": "analysis", "to": "publication", "qualityGate": { "minScore": 85, "requireSelfCheck": true, "requirePeerReview": true, "maxReworks": 2, "validators": ["similarity"], "validatorConfig": { "similarity": { "maxRepeatRatio": 0.3, "minBlockSize": 100 } } } }
      ]
    },
    "floorColor": { "h": 190, "s": 35, "b": 10, "c": 0 },
    "furniture": [
      { "type": "desk", "count": 3 },
      { "type": "bookshelf", "count": 2 },
      { "type": "whiteboard", "count": 1 },
      { "type": "plant", "count": 1 }
    ],
    "order": 7
  }
}
